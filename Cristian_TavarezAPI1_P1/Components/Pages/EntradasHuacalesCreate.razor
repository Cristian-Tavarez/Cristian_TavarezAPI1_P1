@page "/entradashuacales/create"
@rendermode InteractiveServer
@using Cristian_TavarezAPI1_P1.Models
@using Cristian_TavarezAPI1_P1.Services
@using Cristian_TavarezAPI1_P1.Contexto
@using Microsoft.EntityFrameworkCore
@inject EntradasHuacalesService service
@inject AppDbContext context
@inject NavigationManager nav

<div class="row justify-content-center mt-4">
    <div class="col-md-10">
        <div class="card shadow-sm">
            <div class="card-header text-center">
                <h4>Nueva Entrada de Huacales</h4>
            </div>

            <div class="card-body">

                <EditForm Model="entrada" OnValidSubmit="Guardar">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Cliente</label>
                            <InputText class="form-control"
                                       @bind-Value="entrada.NombreCliente" />
                        </div>

                        <div class="col-md-6">
                            <label>Fecha</label>
                            <InputDate class="form-control"
                                       @bind-Value="entrada.Fecha" />
                        </div>
                    </div>

                    <hr />
                    <h5>Detalle de Huacales</h5>

                    <table class="table table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Tipo</th>
                                <th>Cantidad</th>
                                <th>Precio</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in entrada.Detalles!)
                            {
                                <tr>
                                    <td>
                                        <InputSelect class="form-select"
                                                     @bind-Value="item.TipoId">
                                            <option value="">Seleccione</option>
                                            @foreach (var tipo in tipos)
                                            {
                                                <option value="@tipo.TipoId">
                                                    @tipo.Descripcion
                                                </option>
                                            }
                                        </InputSelect>
                                    </td>

                                    <td>
                                        <InputNumber class="form-control"
                                                     @bind-Value="item.Cantidad" />
                                    </td>

                                    <td>
                                        <InputNumber class="form-control"
                                                     @bind-Value="item.Precio" />
                                    </td>

                                    <td>
                                        @(item.Cantidad* item.Precio)
                                    </td>

                                    <td>
                                        <button type="button"
                                                class="btn btn-danger btn-sm"
                                                @onclick="() => QuitarLinea(item)">
                                            X
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <button type="button"
                            class="btn btn-secondary mb-3"
                            @onclick="AgregarLinea">
                        + Agregar Línea
                    </button>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button"
                                class="btn btn-secondary"
                                @onclick="Volver">
                            ← Volver
                        </button>

                        <div>
                            <strong>Total General: </strong>
                            @TotalGeneral()
                        </div>

                        <button type="submit"
                                class="btn btn-success">
                            Guardar
                        </button>
                    </div>

                </EditForm>

            </div>
        </div>
    </div>
</div>

@code {

    EntradaHuacales entrada = new()
    {
        Fecha = DateTime.Now,
        Detalles = new List<EntradaHuacalDetalle>()
    };

    List<TipoHuacal> tipos = new();

    protected override async Task OnInitializedAsync()
    {
        tipos = await context.TiposHuacales.ToListAsync();
        AgregarLinea();
    }

    void AgregarLinea()
    {
        entrada.Detalles!.Add(new EntradaHuacalDetalle());
    }

    void QuitarLinea(EntradaHuacalDetalle item)
    {
        entrada.Detalles!.Remove(item);
    }

    decimal TotalGeneral()
    {
        return entrada.Detalles!
            .Sum(x => x.Cantidad * x.Precio);
    }

    async Task Guardar()
    {
        await service.GuardarAsync(entrada);
        nav.NavigateTo("/entradashuacales");
    }

    void Volver()
    {
        nav.NavigateTo("/entradashuacales");
    }
}