@page "/entradashuacales"
@rendermode InteractiveServer
@using Cristian_TavarezAPI1_P1.Models
@using Cristian_TavarezAPI1_P1.Services
@using Microsoft.AspNetCore.Components.QuickGrid
@inject EntradasHuacalesService service

<h3 class="mb-4">Entradas de Huacales</h3>

<div class="card mb-4 p-3 shadow-sm">
    <div class="row g-3">

        <div class="col-md-3">
            <label>Cliente</label>
            <input class="form-control"
                   placeholder="Nombre del cliente"
                   @bind="filtroCliente"
                   @bind:event="oninput" />
        </div>

        <div class="col-md-2">
            <label>Cantidad</label>
            <input type="number"
                   class="form-control"
                   @bind="filtroCantidad"
                   @bind:event="oninput" />
        </div>

        <div class="col-md-2">
            <label>Precio Mínimo</label>
            <input type="number"
                   class="form-control"
                   @bind="precioMin"
                   @bind:event="oninput" />
        </div>

        <div class="col-md-2">
            <label>Precio Máximo</label>
            <input type="number"
                   class="form-control"
                   @bind="precioMax"
                   @bind:event="oninput" />
        </div>

        <div class="col-md-3">
            <label>Fecha Desde</label>
            <input type="date"
                   class="form-control"
                   @bind="fechaDesde"
                   @bind:event="oninput" />
        </div>

        <div class="col-md-3">
            <label>Fecha Hasta</label>
            <input type="date"
                   class="form-control"
                   @bind="fechaHasta"
                   @bind:event="oninput" />
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-secondary w-100"
                    @onclick="LimpiarFiltros">
                Limpiar Filtros
            </button>
        </div>

    </div>
</div>

<div class="mb-3">
    <b>Cantidad Registros:</b> @listaFiltrada.Count() |
    <b>Total Huacales:</b> @TotalHuacales() |
    <b>Total Dinero:</b> @TotalDinero().ToString("C")
</div>

<a href="/entradashuacales/create" class="btn btn-primary mb-3">
    Nueva Entrada
</a>

<QuickGrid TGridItem="EntradaHuacales"
           Items="listaFiltrada.AsQueryable()"
           Pagination="@pagination"
           Class="table table-striped table-bordered shadow-sm">

    <PropertyColumn Property="@(x => x.NombreCliente)"
                    Title="Cliente"
                    Sortable="true" />

    <PropertyColumn Property="@(x => x.Cantidad)"
                    Title="Cantidad"
                    Sortable="true" />

    <PropertyColumn Property="@(x => x.Precio)"
                    Title="Precio"
                    Format="C"
                    Sortable="true" />

    <PropertyColumn Property="@(x => x.Fecha)"
                    Title="Fecha"
                    Format="dd/MM/yyyy"
                    Sortable="true" />

    <TemplateColumn Title="Acciones">
        <a class="btn btn-warning btn-sm"
           href="/entradashuacales/edit/@context.IdEntrada">
            Editar
        </a>
    </TemplateColumn>

</QuickGrid>

<Paginator State="@pagination" />

@code {

    List<EntradaHuacales> lista = new();

    PaginationState pagination = new() { ItemsPerPage = 2 };

    string? filtroCliente;
    int? filtroCantidad;
    decimal? precioMin;
    decimal? precioMax;
    DateTime? fechaDesde;
    DateTime? fechaHasta;

    IEnumerable<EntradaHuacales> listaFiltrada =>
        lista.Where(x =>

            (string.IsNullOrWhiteSpace(filtroCliente) ||
             (x.NombreCliente != null &&
              x.NombreCliente.Contains(filtroCliente, StringComparison.OrdinalIgnoreCase)))

            &&

            (!filtroCantidad.HasValue ||
             x.Cantidad == filtroCantidad.Value)

            &&

            (!precioMin.HasValue ||
             x.Precio >= precioMin.Value)

            &&

            (!precioMax.HasValue ||
             x.Precio <= precioMax.Value)

            &&

            (!fechaDesde.HasValue ||
             x.Fecha.Date >= fechaDesde.Value.Date)

            &&

            (!fechaHasta.HasValue ||
             x.Fecha.Date <= fechaHasta.Value.Date)
        );

    protected override async Task OnInitializedAsync()
    {
        lista = await service.ListarAsync();
    }

    int TotalHuacales()
    {
        return listaFiltrada.Sum(x => x.Cantidad);
    }

    decimal TotalDinero()
    {
        return listaFiltrada.Sum(x => x.Precio);
    }

    void LimpiarFiltros()
    {
        filtroCliente = null;
        filtroCantidad = null;
        precioMin = null;
        precioMax = null;
        fechaDesde = null;
        fechaHasta = null;
    }
}