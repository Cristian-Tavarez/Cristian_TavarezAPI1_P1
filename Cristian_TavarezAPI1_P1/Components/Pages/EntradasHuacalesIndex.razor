@page "/entradashuacales"
@rendermode InteractiveServer
@using Cristian_TavarezAPI1_P1.Models
@using Cristian_TavarezAPI1_P1.Services
@using Microsoft.AspNetCore.Components.QuickGrid
@inject EntradasHuacalesService service

<h3 class="mb-4">Entradas de Huacales</h3>

<div class="card mb-4 p-3 shadow-sm">
    <div class="row g-3">

        <div class="col-md-3">
            <label>Cliente</label>
            <input class="form-control"
                   placeholder="Nombre del cliente"
                   @bind="filtroCliente"
                   @bind:event="oninput" />
        </div>

        <div class="col-md-2">
            <label>Cantidad Total</label>
            <input type="number"
                   class="form-control"
                   @bind="filtroCantidad"
                   @bind:event="oninput" />
        </div>

        <div class="col-md-2">
            <label>Total Mínimo</label>
            <input type="number"
                   class="form-control"
                   @bind="totalMin"
                   @bind:event="oninput" />
        </div>

        <div class="col-md-2">
            <label>Total Máximo</label>
            <input type="number"
                   class="form-control"
                   @bind="totalMax"
                   @bind:event="oninput" />
        </div>

        <div class="col-md-3">
            <label>Fecha Desde</label>
            <input type="date"
                   class="form-control"
                   @bind="fechaDesde" />
        </div>

        <div class="col-md-3">
            <label>Fecha Hasta</label>
            <input type="date"
                   class="form-control"
                   @bind="fechaHasta" />
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-secondary w-100"
                    @onclick="LimpiarFiltros">
                Limpiar Filtros
            </button>
        </div>

    </div>
</div>

<div class="mb-3">
    <b>Cantidad Registros:</b> @listaFiltrada.Count() |
    <b>Total Huacales:</b> @TotalHuacales() |
    <b>Total Dinero:</b> @TotalDinero().ToString("C")
</div>

<a href="/entradashuacales/create" class="btn btn-primary mb-3">
    Nueva Entrada
</a>

<QuickGrid TGridItem="EntradaHuacales"
           Items="listaFiltrada.AsQueryable()"
           Pagination="@pagination"
           Class="table table-striped table-bordered shadow-sm">

    <PropertyColumn Property="@(x => x.NombreCliente)"
                    Title="Cliente"
                    Sortable="true" />

    <TemplateColumn Title="Tipos">
        @foreach (var detalle in context.Detalles)
        {
            <span class="badge me-1 @ObtenerClaseColor(detalle.TipoHuacal?.Descripcion)">
                @detalle.TipoHuacal?.Descripcion (@detalle.Cantidad)
            </span>
        }
    </TemplateColumn>

    <PropertyColumn Property="@(x => x.CantidadTotal)"
                    Title="Cantidad Total"
                    Sortable="true" />

    <PropertyColumn Property="@(x => x.TotalDinero)"
                    Title="Total Dinero"
                    Format="C"
                    Sortable="true" />

    <PropertyColumn Property="@(x => x.Fecha)"
                    Title="Fecha"
                    Format="dd/MM/yyyy"
                    Sortable="true" />

    <TemplateColumn Title="Acciones">
        <a class="btn btn-warning btn-sm"
           href="/entradashuacales/edit/@context.IdEntrada">
            Editar
        </a>
    </TemplateColumn>

</QuickGrid>

<Paginator State="@pagination" />

@code {

    List<EntradaHuacales> lista = new();

    PaginationState pagination = new() { ItemsPerPage = 5 };

    string? filtroCliente;
    int? filtroCantidad;
    decimal? totalMin;
    decimal? totalMax;
    DateTime? fechaDesde;
    DateTime? fechaHasta;

    IEnumerable<EntradaHuacales> listaFiltrada =>
        lista.Where(x =>

            (string.IsNullOrWhiteSpace(filtroCliente) ||
             (x.NombreCliente != null &&
              x.NombreCliente.Contains(filtroCliente, StringComparison.OrdinalIgnoreCase)))

            &&

            (!filtroCantidad.HasValue ||
             x.CantidadTotal == filtroCantidad.Value)

            &&

            (!totalMin.HasValue ||
             x.TotalDinero >= totalMin.Value)

            &&

            (!totalMax.HasValue ||
             x.TotalDinero <= totalMax.Value)

            &&

            (!fechaDesde.HasValue ||
             x.Fecha.Date >= fechaDesde.Value.Date)

            &&

            (!fechaHasta.HasValue ||
             x.Fecha.Date <= fechaHasta.Value.Date)
        );

    protected override async Task OnInitializedAsync()
    {
        lista = await service.ListarAsync();
    }

    int TotalHuacales()
    {
        return listaFiltrada.Sum(x => x.CantidadTotal);
    }

    decimal TotalDinero()
    {
        return listaFiltrada.Sum(x => x.TotalDinero);
    }

    void LimpiarFiltros()
    {
        filtroCliente = null;
        filtroCantidad = null;
        totalMin = null;
        totalMax = null;
        fechaDesde = null;
        fechaHasta = null;
    }

    string ObtenerClaseColor(string? descripcion)
    {
        return descripcion switch
        {
            "Rojo" => "bg-danger",
            "Verde" => "bg-success",
            _ => "bg-secondary"
        };
    }

}